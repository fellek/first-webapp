# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
APP_NAME="Meine App"
APP_ENV=local
APP_KEY=                        # php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8080

# ─────────────────────────────────────────
# Datenbank
# ─────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db                      # = Service-Name in docker-compose.yml
DB_PORT=3306
DB_DATABASE=app
DB_USERNAME=app_user
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_HOST=redis                # = Service-Name in docker-compose.yml
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─────────────────────────────────────────
# Cache / Queue / Session
# ─────────────────────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─────────────────────────────────────────
# Mail (lokal: Mailpit)
# ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit               # lokal; in Production z.B. smtp.mailgun.net
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# Traefik / SSL (nur Production)
# ─────────────────────────────────────────
APP_DOMAIN=example.com
ACME_EMAIL=admin@example.com

# ─────────────────────────────────────────
# GitHub Container Registry
# ─────────────────────────────────────────
GITHUB_REPOSITORY=dein-github-user/dein-repo-name
